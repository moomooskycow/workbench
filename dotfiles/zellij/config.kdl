    }
}
theme "rose-pine"

// --- Keybinds ----------------------------------------------------------------
// Single-chord session swaps that work from any mode (incl. inside an agent TUI).
// `shared_except "locked"` = fires in every mode except Locked, so Zellij
// intercepts the chord before the focused pane (e.g. Claude/Codex) sees it.
keybinds {
    shared_except "locked" {
        // --- Anti-accidental-quit ---------------------------------------------
        // Zellij's default `Ctrl q` => Quit is a foot-gun: one fat-finger ends
        // the whole session (it becomes resurrectable, but live processes die
        // and, pre-fix, scrollback was lost). Repurpose the reflex key to the
        // SAFE action: Detach. The session keeps running in the background and
        // every pane/process stays alive — reattach with `zellij attach <name>`.
        // Intentional quit is now deliberate only:
        //   • session-manager picker: `Alt o` (kill/exit a session from the list)
        //   • shell: `zellij kill-session <name>` or `zellij delete-session <name>`
        unbind "Ctrl q"
        bind "Ctrl q" { Detach; }

        bind "Alt p" { SwitchSession name="personal"; }
        bind "Alt w" { SwitchSession name="work"; }
        // Open the session-manager picker directly — skips Ctrl-o w mode dance.
        bind "Alt o" {
            LaunchOrFocusPlugin "zellij:session-manager" {
                floating true
                move_to_focused_tab true
            };
        }
        // Alt t — fuzzy TAB switcher (room): a full vertical list, type-to-filter,
        // Enter to jump, or press a tab's number. The fix for "many tabs, one line".
        // (New sessions only — Zellij doesn't hot-reload keybinds. For the current
        //  session use the `zw` shell alias, which does the same thing live.)
        bind "Alt t" {
            LaunchOrFocusPlugin "file:~/.config/zellij/plugins/room.wasm" {
                floating true
                ignore_case true
                quick_jump true
            };
        }
        // Alt 1-9 — jump straight to a tab by index.
        bind "Alt 1" { GoToTab 1; }
        bind "Alt 2" { GoToTab 2; }
        bind "Alt 3" { GoToTab 3; }
        bind "Alt 4" { GoToTab 4; }
        bind "Alt 5" { GoToTab 5; }
        bind "Alt 6" { GoToTab 6; }
        bind "Alt 7" { GoToTab 7; }
        bind "Alt 8" { GoToTab 8; }
        bind "Alt 9" { GoToTab 9; }
    }
}

// --- Plugins -----------------------------------------------------------------
// Keep the compact footer, but let F1 reveal the full keybinding help overlay.
plugins {
    tab-bar location="zellij:tab-bar"
    status-bar location="zellij:status-bar"
    strider location="zellij:strider"
    compact-bar location="zellij:compact-bar" {
        tooltip "F1"
    }
    session-manager location="zellij:session-manager"
    welcome-screen location="zellij:session-manager" {
        welcome_screen true
    }
    filepicker location="zellij:strider" {
        cwd "/"
    }
    configuration location="zellij:configuration"
    plugin-manager location="zellij:plugin-manager"
    about location="zellij:about"
}
