# --- Secrets: DENY BY DEFAULT ---
# Never auto-track env/key files anywhere. A repo-wide `!*/.env` force-include
# used to live here and force-tracked a nested .env, leaking a token. The
# managed dotfiles below are re-included by EXACT path only — no `*/` globs.
.env
.env.*
**/.env
**/.env.*
*.pem
*.key
*_rsa
*_ed25519
!**/.env.example

# Managed dotfiles (force-include the specific tracked copies, rooted paths)
!/dotfiles/.zshrc
!/dotfiles/.aliases
!/dotfiles/.env
!/dotfiles/.fun
!/dotfiles/.tmux.conf

# Development tools
.tool-versions
**/.claude/settings.local.json

# OS-specific files
.DS_Store

# Deprecated glance artifacts
**/glance.md
.glance-output.md

# Python virtual environment
bin/thinktank-venv/
**/__pycache__/
**/*.py[cod]
**/*$py.class
**/*.so
**/.Python
**/pip-log.txt
**/.coverage
**/.coverage.*
**/htmlcov/
**/.tox/
**/.nox/
**/.hypothesis/
**/.pytest_cache/
**/dist/
**/build/

# Pi agent runtime state
.pi/state/

# Logs and temporary directories
logs/
.vercel

# Thinktank output
thinktank.log
thinktank_*/
CODE_REVIEW_*.md
TODO.md
.mcp.json
